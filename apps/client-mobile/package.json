{
  "name": "@kaori/client-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor wrapper around the Natural Beauty client website (iOS + Android shell).",
  "scripts": {
    "build:web": "pnpm --filter @kaori/client-web build && pnpm --filter @kaori/client-web export || true",
    "sync": "cap sync",
    "ios:open": "cap open ios",
    "android:open": "cap open android",
    "ios:run": "cap run ios",
    "android:run": "cap run android"
  },
  "dependencies": {
    "@capacitor/core": "6.2.0",
    "@capacitor/ios": "6.2.0",
    "@capacitor/android": "6.2.0",
    "@capacitor/app": "6.0.2",
    "@capacitor/browser": "6.0.3",
    "@capacitor/preferences": "6.0.3",
    "@capacitor/push-notifications": "6.0.3",
    "@capacitor/status-bar": "6.0.2",
    "@capacitor/splash-screen": "6.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "6.2.0"
  }
}
