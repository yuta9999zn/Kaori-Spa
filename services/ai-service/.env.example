# Copy to .env and fill in. Real .env is gitignored.
ENV=dev

DB_URL=postgresql+asyncpg://kaori:kaori@localhost:5433/kaori_ai
REDIS_URL=redis://localhost:6379/0

# LLM keys — load from secrets manager in production. Never commit values.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-opus-4-7
LLM_MAX_TOKENS=1024

RL_CHAT_PER_MIN=30
